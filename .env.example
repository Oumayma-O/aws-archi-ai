# AWS Configuration
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-5-20250929-v1:0
AWS_PROFILE=default

# Application Configuration
LOG_LEVEL=INFO

# AgentCore Configuration
# Set AGENTCORE_ENABLED=true to use Amazon Bedrock AgentCore managed runtime.
# When false (default), agents run locally via Strands SDK (ECS Fargate fallback).
AGENTCORE_ENABLED=false
AGENTCORE_ENDPOINT=

# DynamoDB Session Store
SESSION_TABLE_NAME=architect-sessions
